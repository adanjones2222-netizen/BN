<style>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
–gold: #c9a84c;
–gold-bright: #e4c76b;
–ink: #0a0a0f;
–smoke: #1a1a24;
–fog: #b0adb8;
–bone: #e8e4dc;
–red-accent: #8b2020;
}

html { scroll-behavior: smooth; }

body {
background: var(–ink);
color: var(–bone);
font-family: ‘Source Sans 3’, sans-serif;
font-weight: 300;
min-height: 100vh;
overflow-x: hidden;
}

/* === ATMOSPHERIC BACKGROUND === */
.atmosphere {
position: fixed;
inset: 0;
z-index: 0;
pointer-events: none;
overflow: hidden;
}

.atmosphere::before {
content: ‘’;
position: absolute;
top: -50%;
left: -50%;
width: 200%;
height: 200%;
background:
radial-gradient(ellipse at 20% 20%, rgba(201,168,76,0.06) 0%, transparent 50%),
radial-gradient(ellipse at 80% 80%, rgba(139,32,32,0.04) 0%, transparent 50%),
radial-gradient(ellipse at 50% 50%, rgba(26,26,36,0.8) 0%, transparent 70%);
animation: drift 30s ease-in-out infinite alternate;
}

.atmosphere::after {
content: ‘’;
position: absolute;
inset: 0;
background: url(“data:image/svg+xml,%3Csvg viewBox=‘0 0 256 256’ xmlns=‘http://www.w3.org/2000/svg’%3E%3Cfilter id=‘noise’%3E%3CfeTurbulence type=‘fractalNoise’ baseFrequency=‘0.9’ numOctaves=‘4’ stitchTiles=‘stitch’/%3E%3C/filter%3E%3Crect width=‘100%25’ height=‘100%25’ filter=‘url(%23noise)’ opacity=‘0.03’/%3E%3C/svg%3E”);
opacity: 0.5;
}

@keyframes drift {
0% { transform: translate(0, 0) rotate(0deg); }
100% { transform: translate(2%, 1%) rotate(1deg); }
}

/* === LAYOUT === */
.page-wrapper {
position: relative;
z-index: 1;
display: flex;
flex-direction: column;
align-items: center;
min-height: 100vh;
padding: 3rem 1.5rem 2rem;
}

/* === COIN ICON === */
.coin {
width: 70px;
height: 70px;
border-radius: 50%;
border: 2px solid var(–gold);
display: flex;
align-items: center;
justify-content: center;
margin-bottom: 1.8rem;
position: relative;
animation: fadeDown 1s ease-out;
box-shadow:
0 0 20px rgba(201,168,76,0.15),
inset 0 0 15px rgba(201,168,76,0.08);
}

.coin::before {
content: ‘E’;
font-family: ‘Playfair Display’, serif;
font-size: 1.8rem;
font-weight: 700;
color: var(–gold);
font-style: italic;
}

.coin::after {
content: ‘’;
position: absolute;
inset: 4px;
border-radius: 50%;
border: 1px solid rgba(201,168,76,0.25);
}

/* === HEADER === */
.author-name {
font-family: ‘Playfair Display’, serif;
font-size: clamp(2.2rem, 6vw, 3.4rem);
font-weight: 900;
letter-spacing: 0.08em;
text-transform: uppercase;
color: var(–bone);
text-align: center;
margin-bottom: 0.3rem;
animation: fadeDown 1s ease-out 0.15s both;
}

.series-label {
font-family: ‘JetBrains Mono’, monospace;
font-size: 0.7rem;
letter-spacing: 0.35em;
text-transform: uppercase;
color: var(–gold);
text-align: center;
margin-bottom: 0.6rem;
animation: fadeDown 1s ease-out 0.3s both;
}

.tagline {
font-family: ‘Playfair Display’, serif;
font-style: italic;
font-size: clamp(1rem, 2.5vw, 1.15rem);
color: var(–fog);
text-align: center;
max-width: 400px;
line-height: 1.6;
margin-bottom: 2.5rem;
animation: fadeDown 1s ease-out 0.45s both;
}

/* === DIVIDER === */
.divider {
width: 50px;
height: 1px;
background: linear-gradient(90deg, transparent, var(–gold), transparent);
margin-bottom: 2.5rem;
animation: fadeDown 1s ease-out 0.5s both;
}

/* === LINK BUTTONS === */
.links-section {
width: 100%;
max-width: 420px;
display: flex;
flex-direction: column;
gap: 0.85rem;
margin-bottom: 3rem;
}

.link-btn {
display: flex;
align-items: center;
gap: 0.9rem;
padding: 0.95rem 1.3rem;
border: 1px solid rgba(201,168,76,0.2);
border-radius: 4px;
background: rgba(26,26,36,0.6);
color: var(–bone);
text-decoration: none;
font-family: ‘Source Sans 3’, sans-serif;
font-size: 0.95rem;
font-weight: 400;
letter-spacing: 0.04em;
transition: all 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
backdrop-filter: blur(10px);
position: relative;
overflow: hidden;
animation: fadeUp 0.8s ease-out both;
}

.link-btn:nth-child(1) { animation-delay: 0.6s; }
.link-btn:nth-child(2) { animation-delay: 0.7s; }
.link-btn:nth-child(3) { animation-delay: 0.8s; }
.link-btn:nth-child(4) { animation-delay: 0.9s; }
.link-btn:nth-child(5) { animation-delay: 1.0s; }
.link-btn:nth-child(6) { animation-delay: 1.1s; }
.link-btn:nth-child(7) { animation-delay: 1.2s; }

.link-btn::before {
content: ‘’;
position: absolute;
inset: 0;
background: linear-gradient(90deg, rgba(201,168,76,0.08), transparent);
opacity: 0;
transition: opacity 0.35s;
}

.link-btn:hover {
border-color: var(–gold);
transform: translateY(-2px);
box-shadow: 0 6px 25px rgba(201,168,76,0.1);
}

.link-btn:hover::before { opacity: 1; }

.link-btn:active { transform: translateY(0); }

.link-icon {
width: 22px;
height: 22px;
flex-shrink: 0;
display: flex;
align-items: center;
justify-content: center;
z-index: 1;
}

.link-icon svg {
width: 100%;
height: 100%;
fill: var(–gold);
}

.link-text {
z-index: 1;
flex: 1;
}

.link-subtitle {
font-size: 0.7rem;
color: var(–fog);
margin-top: 2px;
letter-spacing: 0.02em;
}

.link-arrow {
color: var(–gold);
opacity: 0;
transform: translateX(-5px);
transition: all 0.35s;
z-index: 1;
font-size: 0.85rem;
}

.link-btn:hover .link-arrow {
opacity: 1;
transform: translateX(0);
}

/* === SECTION LABEL === */
.section-label {
font-family: ‘JetBrains Mono’, monospace;
font-size: 0.6rem;
letter-spacing: 0.4em;
text-transform: uppercase;
color: rgba(201,168,76,0.5);
margin-bottom: 1rem;
text-align: center;
animation: fadeUp 0.8s ease-out 0.55s both;
}

/* === QUOTE BLOCK === */
.quote-section {
max-width: 380px;
text-align: center;
margin-bottom: 2.5rem;
animation: fadeUp 0.8s ease-out 1.3s both;
}

.quote-text {
font-family: ‘Playfair Display’, serif;
font-style: italic;
font-size: 0.95rem;
color: var(–fog);
line-height: 1.7;
margin-bottom: 0.5rem;
}

.quote-attr {
font-family: ‘JetBrains Mono’, monospace;
font-size: 0.6rem;
letter-spacing: 0.2em;
color: rgba(201,168,76,0.5);
text-transform: uppercase;
}

/* === SOCIAL ROW === */
.social-row {
display: flex;
gap: 1.5rem;
margin-bottom: 2rem;
animation: fadeUp 0.8s ease-out 1.4s both;
}

.social-icon {
width: 36px;
height: 36px;
border-radius: 50%;
border: 1px solid rgba(201,168,76,0.2);
display: flex;
align-items: center;
justify-content: center;
transition: all 0.3s;
color: var(–fog);
text-decoration: none;
}

.social-icon:hover {
border-color: var(–gold);
background: rgba(201,168,76,0.08);
transform: translateY(-2px);
}

.social-icon svg {
width: 16px;
height: 16px;
fill: var(–fog);
transition: fill 0.3s;
}

.social-icon:hover svg { fill: var(–gold); }

/* === FOOTER === */
.footer {
font-family: ‘JetBrains Mono’, monospace;
font-size: 0.55rem;
letter-spacing: 0.15em;
color: rgba(176,173,184,0.3);
text-align: center;
margin-top: auto;
padding-top: 2rem;
animation: fadeUp 0.8s ease-out 1.5s both;
}

/* === ANIMATIONS === */
@keyframes fadeDown {
from { opacity: 0; transform: translateY(-15px); }
to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeUp {
from { opacity: 0; transform: translateY(15px); }
to { opacity: 1; transform: translateY(0); }
}

/* === MOBILE FINE-TUNING === */
@media (max-width: 480px) {
.page-wrapper { padding: 2.5rem 1.2rem 1.5rem; }
.link-btn { padding: 0.85rem 1.1rem; }
}
</style>

</head>
